<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vantix - Order Management Office</title>
    
    <!-- Premium Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-gradient: linear-gradient(135deg, #0f111a 0%, #151824 100%);
            --card-bg: rgba(30, 34, 51, 0.6);
            --card-hover-bg: rgba(36, 41, 62, 0.85);
            --border-color: rgba(255, 255, 255, 0.08);
            --text-primary: #ffffff;
            --text-secondary: #9aa0b9;
            --text-muted: #62677b;
            
            /* Status Colors */
            --color-buy: #10b981;
            --color-buy-bg: rgba(16, 185, 129, 0.15);
            --color-sell: #ef4444;
            --color-sell-bg: rgba(239, 68, 68, 0.15);
            --color-open: #3b82f6;
            --color-open-bg: rgba(59, 130, 246, 0.15);
            --color-closed: #10b981;
            --color-closed-bg: rgba(16, 185, 129, 0.15);
            --color-rejected: #f59e0b;
            --color-rejected-bg: rgba(245, 158, 11, 0.15);
            
            /* Action Button Colors */
            --btn-approve: #10b981;
            --btn-approve-hover: #059669;
            --btn-decline: #ef4444;
            --btn-decline-hover: #dc2626;
            
            --transition-speed: 0.25s;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background: var(--bg-gradient);
            color: var(--text-primary);
            min-height: 100vh;
            padding: 2rem 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 100%;
            max-width: 1200px;
        }

        header {
            margin-bottom: 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 1.5rem;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .brand-logo {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 1.1rem;
            color: #fff;
            box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
            font-family: 'Outfit', sans-serif;
        }

        .brand-name {
            font-family: 'Outfit', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            background: linear-gradient(to right, #ffffff, #c7d2fe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .subtitle {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .page-title {
            font-family: 'Outfit', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .orders-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1.5rem;
            width: 100%;
        }

        /* Order Card Style */
        .order-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
            backdrop-filter: blur(10px);
            position: relative;
            overflow: hidden;
        }

        .order-card:hover {
            transform: translateY(-4px);
            background: var(--card-hover-bg);
            border-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }

        .symbol-info {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .symbol {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: 0.5px;
        }

        .company-name {
            font-size: 0.8rem;
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 180px;
        }

        /* Badges */
        .badge {
            font-size: 0.75rem;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .badge-buy {
            color: var(--color-buy);
            background: var(--color-buy-bg);
        }

        .badge-sell {
            color: var(--color-sell);
            background: var(--color-sell-bg);
        }

        .badge-open {
            color: var(--color-open);
            background: var(--color-open-bg);
        }

        .badge-closed {
            color: var(--color-closed);
            background: var(--color-closed-bg);
        }

        .badge-rejected {
            color: var(--color-rejected);
            background: var(--color-rejected-bg);
        }

        .order-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem 0.5rem;
            padding: 1rem 0;
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 1.25rem;
        }

        .detail-item {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .detail-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .detail-value {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .order-meta {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-bottom: 1.25rem;
        }

        /* Action Buttons */
        .card-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: auto;
        }

        .btn {
            flex: 1;
            padding: 10px 16px;
            border: none;
            border-radius: 10px;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-approve {
            background-color: var(--btn-approve);
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        }

        .btn-approve:hover {
            background-color: var(--btn-approve-hover);
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(16, 185, 129, 0.35);
        }

        .btn-approve:active {
            transform: translateY(0);
        }

        .btn-decline {
            background-color: rgba(239, 68, 68, 0.1);
            color: var(--color-sell);
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .btn-decline:hover {
            background-color: var(--btn-decline);
            color: #ffffff;
            border-color: transparent;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(239, 68, 68, 0.3);
        }

        .btn-decline:active {
            transform: translateY(0);
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }

        /* Empty State */
        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 5rem 2rem;
            background: var(--card-bg);
            border: 1px dashed var(--border-color);
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .empty-icon {
            font-size: 3rem;
            color: var(--text-muted);
        }

        .empty-text {
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

        /* Toast Notification */
        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .toast {
            background: #1e2233;
            border: 1px solid var(--border-color);
            border-left: 4px solid #6366f1;
            color: #fff;
            padding: 12px 24px;
            border-radius: 8px;
            font-size: 0.9rem;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 280px;
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }

        .toast.success {
            border-left-color: var(--color-buy);
        }

        .toast.error {
            border-left-color: var(--color-sell);
        }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <div class="brand">
                <div class="brand-logo">V</div>
                <div>
                    <h1 class="brand-name">Vantix Trading</h1>
                    <p class="subtitle">Internal Order Approval Office</p>
                </div>
            </div>
            <div class="page-title">Pending Approvals</div>
        </header>

        <div class="orders-grid">
            <% if (typeof data !== 'undefined' && data && data.length > 0) { %>
                <% data.forEach(order => { %>
                    <div class="order-card" id="order-card-<%= order._id %>">
                        <div class="order-header">
                            <div class="symbol-info">
                                <span class="symbol"><%= order.symbol %></span>
                                <span class="company-name" title="<%= order.name %>"><%= order.name %></span>
                            </div>
                            <div style="display: flex; gap: 6px;">
                                <span class="badge badge-<%= order.action.toLowerCase() %>"><%= order.action %></span>
                                <span class="badge badge-<%= (order.status || 'PENDING').toLowerCase() %>" id="status-badge-<%= order._id %>">
                                    <%= order.status || 'PENDING' %>
                                </span>
                            </div>
                        </div>

                        <div class="order-details">
                            <div class="detail-item">
                                <span class="detail-label">Quantity</span>
                                <span class="detail-value"><%= order.qty %></span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Price</span>
                                <span class="detail-value">$<%= order.price.toFixed(2) %></span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Product</span>
                                <span class="detail-value"><%= order.product %></span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Type</span>
                                <span class="detail-value"><%= order.type %></span>
                            </div>
                            
                            <% if (order.limitPrice > 0) { %>
                                <div class="detail-item">
                                    <span class="detail-label">Limit Price</span>
                                    <span class="detail-value">$<%= order.limitPrice.toFixed(2) %></span>
                                </div>
                            <% } %>
                            <% if (order.stopLossPrice > 0) { %>
                                <div class="detail-item">
                                    <span class="detail-label">Stop Loss</span>
                                    <span class="detail-value">$<%= order.stopLossPrice.toFixed(2) %></span>
                                </div>
                            <% } %>
                        </div>

                        <div class="order-meta">
                            <span>Date: <%= order.date %></span>
                            <span>Time: <%= order.time %></span>
                        </div>

                        <div class="card-actions" id="actions-<%= order._id %>">
                            <button 
                                class="btn btn-decline" 
                                onclick="processOrder('<%= order._id %>', 'decline')"
                                id="btn-decline-<%= order._id %>">
                                Decline
                            </button>
                            <button 
                                class="btn btn-approve" 
                                onclick="processOrder('<%= order._id %>', 'approve')"
                                id="btn-approve-<%= order._id %>">
                                Approve
                            </button>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon">📁</div>
                    <div class="empty-text">No pending orders available to display.</div>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Toast Notifications Container -->
    <div class="toast-container" id="toast-container"></div>

    <script>
        // Store access token globally once acquired
        let cachedAccessToken = null;

        // Function to show toast notifications
        function showToast(message, type = 'success') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `
                <span>${type === 'success' ? '✓' : '✗'}</span>
                <div>${message}</div>
            `;
            container.appendChild(toast);
            
            // Trigger animation
            setTimeout(() => toast.classList.add('show'), 10);

            // Remove toast after 4 seconds
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        // Retrieve and refresh the access token using cookie credential
        async function getAccessToken() {
            if (cachedAccessToken) return cachedAccessToken;

            try {
                const res = await fetch('/api/token/refresh');
                if (res.ok) {
                    cachedAccessToken = await res.text();
                    return cachedAccessToken;
                }
            } catch (err) {
                console.error("Authentication refresh failed:", err);
            }
            return null;
        }

        // Process Approve or Decline action
        async function processOrder(orderId, action) {
            const approveBtn = document.getElementById(`btn-approve-${orderId}`);
            const declineBtn = document.getElementById(`btn-decline-${orderId}`);
            const statusBadge = document.getElementById(`status-badge-${orderId}`);
            
            // Disable buttons during request
            if (approveBtn) approveBtn.disabled = true;
            if (declineBtn) declineBtn.disabled = true;

            try {
                // Get JWT access token
                const token = await getAccessToken();
                const headers = {
                    'Content-Type': 'application/json'
                };
                if (token) {
                    headers['Authorization'] = `Bearer ${token}`;
                }

                // Prepare order status payload
                // The API endpoint PATCH /orders/:id sets status to "CLOSED" (which acts as Approve)
                // For decline, we will attempt to patch status to "REJECTED" or default behavior.
                const statusValue = action === 'approve' ? 'CLOSED' : 'REJECTED';
                
                const response = await fetch(`/orders/${orderId}`, {
                    method: 'PATCH',
                    headers: headers,
                    body: JSON.stringify({ status: statusValue })
                });

                if (response.ok) {
                    const result = await response.json();
                    showToast(`Order successfully ${action}d!`, 'success');
                    
                    // Update badge UI
                    if (statusBadge) {
                        statusBadge.textContent = statusValue;
                        statusBadge.className = `badge badge-${statusValue.toLowerCase()}`;
                    }

                    // Disable or hide actions upon completion
                    const actionsContainer = document.getElementById(`actions-${orderId}`);
                    if (actionsContainer) {
                        actionsContainer.innerHTML = `<span style="color: var(--text-muted); font-size: 0.875rem; text-align: center; width: 100%;">Action Taken: ${action.toUpperCase()}</span>`;
                    }
                } else {
                    const errorText = await response.text();
                    let errMsg = `Failed to ${action} order.`;
                    try {
                        const errJson = JSON.parse(errorText);
                        errMsg = errJson.message || errMsg;
                    } catch (e) {}
                    
                    showToast(errMsg, 'error');
                    
                    // Re-enable buttons on failure
                    if (approveBtn) approveBtn.disabled = false;
                    if (declineBtn) declineBtn.disabled = false;
                }
            } catch (error) {
                console.error(`Error processing ${action}:`, error);
                showToast(`Network error. Please try again.`, 'error');
                
                // Re-enable buttons on error
                if (approveBtn) approveBtn.disabled = false;
                if (declineBtn) declineBtn.disabled = false;
            }
        }
    </script>
</body>
</html>
